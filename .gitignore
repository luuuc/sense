/testdata/.sense/
/assets

# ----------------------------------------------------------------------------
# Bench harness (per-run results)
# ----------------------------------------------------------------------------
bench/improvement-loop/results/
bench/analysis/
bench/tools/
bench/CHANGELOG.md
/.council

# Host-built sense indexes staged into the docker build context by
# bench/build-prescan.sh. Each one is ~350MB (nextjs.sense) and is
# regenerated on demand from $SENSE_BENCH_ROOT/sense/<repo>/.sense.
bench/docker/sense/preindex/

# Local-only bench result snapshots (manual backups before full sweeps).
bench/results.snapshot-*/
bench/results/report-*.md
bench/results/report-for-humans-*.md

# Generated reports under a vertical's results tree (matrix + per-model reports +
# citation report). The run data is tracked; these derive from it on demand via
# report-matrix.sh / report.sh, so they are regenerated, not committed. (The
# global bench/results/report.md|json stay tracked by design.)
bench/results/vertical/**/report.md
bench/results/vertical/**/report.json
bench/results/vertical/**/citation-hallucinations.md
bench/bench-sense-local.sh
/bench/embed-recall

# Local scratch: Python coverage DB and scenario backups taken while
# reworking a seam (e.g. forem.embed.yaml.bak before the reaction rewrite).
bench/lib/.coverage
bench/scenarios/*.bak
.local/
