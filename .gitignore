!bench/global/docker/**/CLAUDE.md
.claude.json
.mcp.json
.opencode/
.cursor/
.cursorrules
.cursorignore
.opencode/
opencode.json
.codex/
.aider*
.continue/
.windsurf/
AGENTS.md

